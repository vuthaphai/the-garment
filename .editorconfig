# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Java / XML / YAML
[*.{java,xml,yml,yaml,properties}]
indent_style = space
indent_size = 4

# JSON / HTML / CSS / TypeScript / SCSS
[*.{json,html,ts,scss,css}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
